{
  "info": {
    "_postman_id": "d4f8f696-4c53-4f16-bc1f-8d4dbedc147a",
    "name": "App Harinas API",
    "description": "Coleccion para probar autenticacion y CRUD de harinas",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "Harinas - Listar",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/harinas",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "harinas"
          ]
        }
      }
    },
    {
      "name": "Harinas - Crear",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Harina de maiz\",\n  \"tipo\": \"Precocida\",\n  \"cantidad\": 50,\n  \"unidad\": \"kg\",\n  \"fecha_registro\": \"2026-01-01\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/harinas",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "harinas"
          ]
        }
      }
    },
    {
      "name": "Harinas - Actualizar",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Harina de maiz amarillo\",\n  \"tipo\": \"Precocida\",\n  \"cantidad\": 75,\n  \"unidad\": \"kg\",\n  \"fecha_registro\": \"2026-01-01\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/harinas/{{harinaId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "harinas",
            "{{harinaId}}"
          ]
        }
      }
    },
    {
      "name": "Harinas - Eliminar",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/harinas/{{harinaId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "harinas",
            "{{harinaId}}"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "harinaId",
      "value": ""
    },
    {
      "key": "adminEmail",
      "value": "admin@nativa.com"
    },
    {
      "key": "adminPassword",
      "value": "admin123"
    }
  ]
}
