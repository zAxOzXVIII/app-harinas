# Gateway solo para Arduino Uno (sin Wi‑Fi). Produccion: usar firmware ESP32.
# Ver ../README.md — este gateway es ruta temporal de desarrollo.
#
# Puerto COM del Arduino (USB) o del HC-05 emparejado en Windows
# Administrador de dispositivos → Puertos (COM y LPT)
SERIAL_PORT=COM3
SERIAL_BAUD=115200

# Backend Nativa (local, ngrok o Render)
API_URL=http://localhost:4000/api/arduino/telemetry

# Si usas ngrok/Render con https, deja en 1 (acepta cert self-signed en dev)
API_INSECURE_TLS=0
